# ============================================================
#  StudentsHub — Root environment variables
#  Copy to .env and fill in your values before running Docker.
#  Run:  cp .env.example .env
# ============================================================

# ---- Application ----------------------------------------
APP_ENV=production
APP_DEBUG=false
APP_KEY=                        # Generate: php artisan key:generate --show
APP_URL=http://localhost
APP_PORT=80                     # Host port mapped to Nginx container

# ---- Database -------------------------------------------
DB_DATABASE=studentshuib
DB_USERNAME=sh_user
DB_PASSWORD=change_me_db_secret

# ---- Redis ----------------------------------------------
REDIS_PASSWORD=change_me_redis_secret

# ---- Mail -----------------------------------------------
# MAIL_MAILER=log sends emails to storage/logs/laravel.log (good for dev).
# For production use smtp, mailgun, ses, etc.
MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@diu.edu.bd

# ---- Storage --------------------------------------------
# Controls which filesystem disk Laravel uses for uploads.
# "local" stores files in storage/app. Must match FILESYSTEM_DISK in docker-compose.yml.
FILESYSTEM_DISK=local

# ---- SMS Gateway (SSL Wireless Bangladesh) --------------
# Leave blank to disable SMS notifications.
SMS_GATEWAY_URL=
SMS_GATEWAY_KEY=

# ---- AI Service (Phase 5+, optional) --------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
