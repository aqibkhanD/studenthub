APP_NAME="StudentsHub"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=studentshuib
DB_USERNAME=sh_user
DB_PASSWORD=REMOVED_DB_PASSWORD

BROADCAST_DRIVER=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=REMOVED_REDIS_PASSWORD
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@diu.edu.bd"
MAIL_FROM_NAME="${APP_NAME}"

FRONTEND_URL=http://localhost:3000

# SSL Wireless SMS Gateway (Bangladesh) — Phase 1 onwards
SMS_GATEWAY_URL=
SMS_GATEWAY_KEY=
SMS_SENDER_ID=DIUSMS

# FastAPI AI Service — Phase 4 only
AI_SERVICE_URL=http://ai:8000
AI_SERVICE_TIMEOUT=30
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
